NODE_ENV=development
PORT=8787
HOST=0.0.0.0

# Use DATABASE_URL or explicit PG* variables.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/jungle_game
PGSSL=false

# Required: long random secret for signing session tokens.
SESSION_SIGNING_SECRET=change-this-to-a-long-random-secret
SESSION_TOKEN_TTL_SECONDS=86400

# CORS config for Electron / local testing.
CORS_ORIGIN=*

# Rate limits
RATE_LIMIT_MAX_PER_MINUTE=120
SUBMIT_RATE_LIMIT_PER_PLAYER_PER_MINUTE=20
AUTO_MIGRATE_ON_START=true
