{
  "name": "enterprise-software-electron",
  "version": "1.0.2",
  "description": "Base Electron app scaffold",
  "main": "src/main/main.js",
  "build": {
    "appId": "com.monkeybananaholdings.junglegame",
    "productName": "Jungle Game",
    "publish": [
      {
        "provider": "github",
        "owner": "KortSchaefer",
        "repo": "Jungle-Game",
        "releaseType": "release"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "src/main/**",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "scripts": {
    "start": "electron .",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && set ELECTRON_RENDERER_URL=http://localhost:5173&& electron .",
    "build:renderer": "vite build",
    "build": "npm run build:renderer",
    "preview": "vite preview",
    "clean": "if exist dist rmdir /s /q dist",
    "pack": "npm run build:renderer && electron-builder --dir",
    "dist": "npm run build:renderer && electron-builder",
    "dist:publish": "npm run build:renderer && electron-builder --publish always",
    "release:publish": "powershell -ExecutionPolicy Bypass -File scripts/release.ps1",
    "test": "echo \"No tests configured\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "asar": "^3.2.0",
    "electron": "^40.4.1",
    "electron-builder": "^26.7.0",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "electron-updater": "^6.8.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "wait-on": "^9.0.4"
  }
}
